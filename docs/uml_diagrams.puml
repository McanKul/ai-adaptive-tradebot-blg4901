@startuml Activity_SignalFlow
!theme cerulean-outline
title <size:18>**Activity Diagram - Signal Processing Flow**</size>

skinparam {
  shadowing true
  defaultFontSize 12
  ActivityFontSize 12
  ArrowColor #2C3E50
  ArrowThickness 2
}

skinparam activity {
  BackgroundColor #D6EAF8
  BorderColor #2980B9
  FontStyle bold
}

skinparam diamond {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
}

|#EBF5FB| Data Layer
start
:Bar Completed;

|#E8DAEF| Intelligence Layer
:Strategy.on_bar(bar, ctx);

if (Signal generated?) then (<color:#27AE60>yes</color>)
  :strategy_signal = BUY/SELL;

  if (News enabled?) then (<color:#27AE60>yes</color>)
    |#FDEBD0| News Layer
    :Fetch news articles;
    :Analyze sentiment\n(OpenAI / Gemini);
    :sentiment_score = [0.0 - 1.0];

    |#E8DAEF| Intelligence Layer
    :SignalCombiner.combine();

    if (BUY + sentiment > 0.6?) then (<color:#27AE60>yes</color>)
      #ABEBC6:final_signal = **LONG (+1)**;
    elseif (SELL + sentiment < 0.4?) then (<color:#27AE60>yes</color>)
      #F1948A:final_signal = **SHORT (-1)**;
    else (<color:#C0392B>mixed</color>)
      #D5D8DC:final_signal = None;
      stop
    endif
  else (<color:#7F8C8D>no</color>)
    :final_signal = strategy_signal;
  endif

  |#FADBD8| Risk Layer
  :RiskManager.pre_trade_check();

  if (Approved?) then (<color:#27AE60>yes</color>)
    |#D1F2EB| Execution Layer
    :Calculate position size;
    :Execute market order;
    :Place TP/SL orders;
    :Update position tracking;
  else (<color:#C0392B>no</color>)
    #F1948A:Log rejection reason;
  endif

else (<color:#7F8C8D>no</color>)
  #D5D8DC:No action;
endif

stop

