participant "app.py" as CLI #FAD7A0
participant "BacktestService" as Svc #F7DC6F
participant "StrategyFactory" as SF #FCF3CF
participant "BacktestEngine" as Engine #FADBD8
participant "DiskTickStreamer" as Stream #AED6F1
participant "BarBuilder" as BB #D6EAF8
participant "IStrategy" as Strat #D2B4DE
participant "RiskManager" as Risk #F1948A
participant "ExecutionModel" as Exec #ABEBC6
participant "Portfolio" as Port #F9E79F
participant "MetricsSink" as Metrics #ABEBC6

User -[#E67E22]> CLI: backtest --strategy ...
CLI -[#D4AC0D]> Svc: run_single(config)
activate Svc #F7DC6F
Svc -[#D4AC0D]> SF: resolve_class(name)
SF --[#D4AC0D]> Svc: strategy instance
Svc -[#E74C3C]> Engine: run(strategy, sizing)
activate Engine #FADBD8

loop #EBF5FB for each Tick
  Engine -[#2980B9]> Stream: next tick
  Engine -[#2980B9]> BB: on_tick(tick)
  alt #D5F5E3 bar completed
    BB --[#27AE60]> Engine: Bar
    Engine -[#8E44AD]> Strat: on_bar(bar, ctx)
    Strat --[#8E44AD]> Engine: StrategyDecision (orders)
    loop #FEF9E7 for each Order
      Engine -[#C0392B]> Risk: pre_trade_check(order)
      alt #D5F5E3 approved
        Engine -[#27AE60]> Exec: process_orders(order, bar)
        Exec --[#27AE60]> Engine: Fill
        Engine -[#F39C12]> Port: apply_fill(fill)
        Engine -[#27AE60]> Metrics: on_fill(fill, equity)
      end
    end
    Engine -[#27AE60]> Engine: _check_tick_exit (TP/SL/trail)
    Engine -[#27AE60]> Metrics: on_bar(bar, equity, position)
  end
end

Engine -[#27AE60]> Metrics: finalize()
Metrics --[#27AE60]> Svc: BacktestResult
deactivate Engine
Svc --[#D4AC0D]> User: print_result()
deactivate Svc

