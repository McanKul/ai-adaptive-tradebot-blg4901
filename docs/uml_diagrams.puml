interface IStrategy <<iface>> {
  +generate_signal(symbol): Optional[str]
  +on_bar(bar, ctx): StrategyDecision
  +reset()
  +get_exit_params(): Dict
  +get_exit_manager(): Optional
}
interface IRegimeDetector <<iface>> {
  +detect(bar, ctx): RegimeState
}
interface IBroker <<iface>> {
  +get_mark_price(symbol): float
  +market_order(symbol, side, qty)
  +close_position(symbol)
  +place_stop_market(...) : int
  +place_take_profit(...) : int
  +wait_for_fill(symbol, id, timeout): dict
  +balance(asset): float
}
interface IClient <<iface>> {
  +futures_create_order(**kwargs)
  +futures_position_information(symbol)
  +futures_klines(symbol, interval, limit)
  +futures_account_balance()
}
interface IStreamer <<iface>> {
  +start() / stop()
  +get_queue(): asyncio.Queue
  +preload_history(...)
}
interface INewsSource <<iface>> {
  +fetch_news(symbol, limit): List[NewsArticle]
}
interface ISentimentAnalyzer <<iface>> {
  +analyze(texts, symbol): float
}
interface IMarginAdjuster <<iface>> {
  +compute_margin_multiplier(direction, sentiment): float
}

class StrategyDecision <<dataclass>> {
  +orders: List[Order]
  +signal: Optional[str]
  +features: Dict
  +metadata: Dict
  +regime_tags: List[str]
}
class RegimeState <<dataclass>> {
  +tags: List[str]
  +score: Dict[str, float]
}
class StrategyContext <<dataclass>> {
  +symbol / timeframe
  +bar_store / portfolio / position
  +equity / cash / timestamp_ns
  +get_ohlcv(limit): Dict
}
class SizingConfig <<dataclass>> {
  +mode: SizingMode
  +fixed_qty / notional_usd / margin_usd
  +leverage / leverage_mode
  +compute_qty(price): float
}
class StrategySlot <<dataclass>> {
  +id: str
  +strategy: IStrategy
  +weight / entry_coefficient
  +sizing: SizingConfig
  +exit: ExitConfig
  +regimes: List[str]
  +enabled: bool
}

class Bar <<dataclass>> {
  +symbol / timeframe / timestamp_ns
  +open/high/low/close/volume
}
class Tick <<dataclass>> {
  +symbol / timestamp_ns / price / volume
}
class Order <<dataclass>> {
  +symbol / side: OrderSide
  +order_type: OrderType
  +quantity / price / stop_price
  +strategy_id / reduce_only / metadata
}
class Fill <<dataclass>> {
  +order_id / symbol / side
  +fill_price / fill_quantity
  +fee / slippage / metadata
}
enum OrderSide <<enum>> {
  BUY
  SELL
}
enum OrderType <<enum>> {
  MARKET
  LIMIT
  STOP_MARKET
  TAKE_PROFIT
}

IStrategy ..> StrategyDecision
IStrategy ..> StrategyContext
IRegimeDetector ..> RegimeState
StrategySlot --> IStrategy
StrategySlot --> SizingConfig
Order --> OrderSide
Order --> OrderType

note bottom of IMarginAdjuster
  Replaces the deprecated **ISignalCombiner**.
  Sentiment no longer gates the signal — it
  scales position margin (boost up to +50%).
end note

