  HeaderBackgroundColor #F4D03F
}
skinparam class<<factory>> {
  BackgroundColor #FCF3CF
  BorderColor #D4AC0D
  HeaderBackgroundColor #F9E79F
}
skinparam class<<util>> {
  BackgroundColor #F2F3F4
  BorderColor #7F8C8D
