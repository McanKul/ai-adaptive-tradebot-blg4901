@startuml Class_Core_Orchestration
!theme cerulean-outline
title <size:18>**Core — Orchestration Layer (Services & Factories)**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
