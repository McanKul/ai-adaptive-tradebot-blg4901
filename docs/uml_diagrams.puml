participant "SignalCombiner" as SC #F5CBA7

Engine -[#E67E22]> NE: get_sentiment("BTCUSDT")
activate NE #FDEBD0

alt #FEF9E7 cache miss or expired
  NE -[#27AE60]> Source: fetch_news("BTCUSDT", limit=10)
  activate Source #D5F5E3
  Source --[#27AE60]> NE: List[NewsArticle]
  deactivate Source

  NE -[#E67E22]> NE: extract titles + content
  NE -[#8E44AD]> SA: analyze(texts, "BTCUSDT")
  activate SA #E8DAEF
  SA --[#8E44AD]> NE: sentiment_score (0.0 - 1.0)
  deactivate SA
  NE -[#E67E22]> NE: cache result
end

NE --[#E67E22]> Engine: sentiment_score
deactivate NE

Engine -[#E67E22]> SC: combine(strategy_signal=BUY, sentiment=0.75)
activate SC #FDEBD0

alt #D5F5E3 BUY + sentiment > 0.6
  SC --[#27AE60]> Engine: **+1 (LONG)**
else #FADBD8 SELL + sentiment < 0.4
  SC --[#C0392B]> Engine: **-1 (SHORT)**
else #F2F3F4 mixed signals
  SC --[#7F8C8D]> Engine: **None (NO ACTION)**
end

