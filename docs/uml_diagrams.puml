}

class BacktestService <<service>> {
  +run_single(strategy_name, params, symbol, ...): BacktestResult
  +run_with_cv(...): BatchResult
  +export_trades(result, path, ...)
  +print_result(result)
  -_build_sizing(...): SizingConfig
}
class SweepService <<service>> {
  +run_sweep(strategy_name, param_grid, symbol, ...): List[RankedResult]
  +print_top_results(results, top_n)
  -_build_search_space(grid, constraints)
  -_build_selection_criteria(...): SelectionCriteria
}
class LiveService <<service>> {
  +run(config_path, dry_run, run_id, sentiment_override): async
  -_validate_live_strategy_safety(cfg, dry_run)
}

class StrategyFactory <<factory>> {
  -_registry: dict[str, str]
  +register(name, module_path)
  +resolve_class(name): type
  +create(name, **kwargs): IStrategy
  +list_available(): list[str]
}
class CompositeFactory <<factory>> {
  +from_spec(spec, regime_detector): CompositeStrategy
  +from_path(path, regime_detector): CompositeStrategy
}
class RegimeFactory <<factory>> {
  -_registry: dict[str, str]
  +register(name, dotted_path)
  +from_spec(spec): IRegimeDetector
}
class BrokerFactory <<factory>> {
  +create(mode, cfg): (IBroker, client)
}
class NewsFactory <<factory>> {
  -_providers: dict[str, Callable]
  +register_provider(name, creator)
  +create(cfg): NewsComponents
}
class NewsComponents <<util>> {
  +news_source: INewsSource
  +sentiment_analyzer: ISentimentAnalyzer
  +margin_adjuster: IMarginAdjuster
}

class ConfigValidator <<util>> {
  +validate(config_path, real_money): List[str]
  -_real_money_checks(cfg): List[str]
}
class bootstrap <<util>> {
  +register_defaults()
}

bootstrap ..> StrategyFactory : registers strategies
bootstrap ..> RegimeFactory : registers detectors
bootstrap ..> NewsFactory : registers providers

BacktestService --> StrategyFactory
BacktestService --> CompositeFactory
SweepService --> StrategyFactory
LiveService --> StrategyFactory
LiveService --> CompositeFactory
LiveService --> BrokerFactory
LiveService --> NewsFactory
CompositeFactory --> StrategyFactory
CompositeFactory --> RegimeFactory
NewsFactory --> NewsComponents
ConfigValidator ..> StrategyFactory

note bottom of LiveService
  Services are **thin orchestrators**:
  factories build concrete impls,
  service wires them, then hands
  control to BacktestEngine / LiveEngine.
end note

@enduml


