class BatchBacktest <<batch>> {
  -config: BacktestConfig
  -strategy_factory: StrategyFactory
  -scorer: Scorer
  +run(search_space, cv): BatchResult
}
class BatchResult <<dataclass>> {
  +results / scores / params_list / rankings
  +cv_method / cv_fold_details
  +selection_bias_report
  +top_k() / best_result()
}
class Scorer <<batch>> {
  -weights: ScorerWeights
  -min_trades / min_sharpe
  +score(result): float
  +score_breakdown(result): Dict
}
class ScorerWeights <<dataclass>> {
  +sharpe / max_drawdown / turnover
  +costs / win_rate / calmar
}
class SearchSpace <<batch>> {
  +add(param, values)
  +add_constraint(fn)
}
class ParameterGrid <<batch>> {
  +from_ranges(...)
}
class Selector <<batch>> {
  +filter(results, criteria): List[RankedResult]
}
class BacktestRunner <<batch>> {
  +run_once(factory, params, name): BacktestResult
}

class PurgedKFold <<batch>>
class WalkForward <<batch>>
class CPCV <<batch>>

BatchBacktest --> Scorer
BatchBacktest --> SearchSpace
BatchBacktest ..> ParameterGrid
BatchBacktest --> BatchResult
BatchBacktest ..> PurgedKFold
BatchBacktest ..> WalkForward
BatchBacktest ..> CPCV
BatchBacktest --> BacktestRunner
Scorer --> ScorerWeights
Selector ..> BatchResult

note bottom of Scorer
  AFML-aware: deflated Sharpe +
  selection-bias warning on
  multi-trial parameter sweeps.
end note

