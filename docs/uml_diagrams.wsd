BST -[#8E44AD]-> STRAT
REG -[#8E44AD]-> STRAT
NE -[#E67E22]-> MA

STRAT -[#C0392B]-> RM
STRAT -[#C0392B]-> GR
MA -[#E67E22]-> PM
RM -[#27AE60]-> EM
GR -[#1ABC9C]-> BRK
EM -[#F39C12]-> PF
BRK -[#1ABC9C]-> PM
RC -[#C0392B]-> GR
PF -[#27AE60]-> MS
PM -[#1ABC9C]-> LM

@enduml

' ============================================================
@startuml State_Position
!theme cerulean-outline
title <size:18>**State Diagram - Position Lifecycle**</size>

skinparam {
  shadowing true
  defaultFontSize 12
  ArrowColor #2C3E50
  ArrowThickness 2
}
skinparam state {
  FontSize 13
  FontStyle bold
  BackgroundColor #D6EAF8
  BorderColor #2980B9
}
skinparam state<<danger>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
}
skinparam state<<success>> {
  BackgroundColor #D5F5E3
  BorderColor #27AE60
}
skinparam state<<active>> {
  BackgroundColor #FDEBD0
  BorderColor #E67E22
}

[*] --> NoPosition

state NoPosition <<success>>
state PendingOpen <<active>>
state Open <<active>>
state TrailingStop <<active>>
state PendingClose <<active>>
state Closed <<success>>
state Liquidated <<danger>>

NoPosition -[#2980B9,bold]-> PendingOpen : Signal received
PendingOpen -[#27AE60,bold]-> Open : Order filled
PendingOpen -[#C0392B]-> NoPosition : Order rejected / slippage abort

Open -[#E67E22]-> TrailingStop : Trailing stop active
Open -[#C0392B]-> PendingClose : TP/SL triggered
Open -[#C0392B]-> PendingClose : Max bars reached
Open -[#E74C3C,bold]-> Liquidated : Liquidation guard

TrailingStop -[#C0392B]-> PendingClose : Trail / TP triggered

PendingClose -[#27AE60,bold]-> Closed : Close order filled
Closed -[#2980B9]-> NoPosition : Reset

Liquidated -[#E74C3C]-> NoPosition : Reset

@enduml

' ============================================================
@startuml State_Order
!theme cerulean-outline
title <size:18>**State Diagram - Order Lifecycle**</size>

skinparam {
  shadowing true
  defaultFontSize 12
  ArrowColor #2C3E50
  ArrowThickness 2
}
skinparam state {
  FontSize 13
  FontStyle bold
  BackgroundColor #D6EAF8
  BorderColor #2980B9
}
skinparam state<<warning>> {
  BackgroundColor #FDEBD0
  BorderColor #E67E22
}
skinparam state<<success>> {
  BackgroundColor #D5F5E3
  BorderColor #27AE60
}
skinparam state<<danger>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
}

[*] -[#2980B9,bold]-> PENDING : Order created

state PENDING
state FILLED <<success>>
state PARTIALLY_FILLED <<warning>>
state CANCELLED <<danger>>
state REJECTED <<danger>>

PENDING -[#27AE60,bold]-> FILLED : Fully executed
PENDING -[#E67E22]-> PARTIALLY_FILLED : Partial execution
PENDING -[#C0392B]-> CANCELLED : Cancelled by user/system
PENDING -[#E74C3C]-> REJECTED : Risk check failed

PARTIALLY_FILLED -[#27AE60,bold]-> FILLED : Remaining filled
PARTIALLY_FILLED -[#C0392B]-> CANCELLED : Cancelled remainder

FILLED -[#27AE60]-> [*]
CANCELLED -[#C0392B]-> [*]
REJECTED -[#E74C3C]-> [*]

@enduml

' ============================================================
@startuml UseCase
!theme cerulean-outline
title <size:20>**Use Case Diagram**</size>\n<size:14>AI-Adaptive Trading Bot</size>

skinparam {
  shadowing true
  defaultFontSize 12
  ArrowColor #34495E
  ArrowThickness 1.5
}
skinparam usecase {
  BackgroundColor #D6EAF8
  BorderColor #2980B9
  FontSize 11
  FontStyle bold
}
skinparam actor {
  FontSize 13
  FontStyle bold
}
skinparam rectangle {
  BorderColor #2C3E50
  BackgroundColor #FDFEFE
  FontSize 16
  FontStyle bold
}

left to right direction

actor "Trader" as trader #F9E79F
actor "Binance API" as binance #AED6F1
actor "News / LLM API" as newsapi #F5CBA7

rectangle "AI-Adaptive Trading Bot" {
  usecase "Run Backtest" as UC1 #FADBD8
  usecase "Sweep / Cross-Validate" as UC2 #FADBD8
  usecase "Configure / Compose Strategy" as UC3 #E8DAEF
  usecase "Validate Config\n(real-money gate)" as UC4 #FCF3CF
  usecase "Promote to Live" as UC5 #FCF3CF
  usecase "Start Live / Dry-Run" as UC6 #D1F2EB
  usecase "Adjust Margin\nby Sentiment" as UC7 #FDEBD0
  usecase "Manage Risk\n(kill-switch)" as UC8 #FADBD8
  usecase "Monitor Positions" as UC9 #D1F2EB

  UC1 .[#7F8C8D].> UC3 : <<include>>
  UC2 .[#7F8C8D].> UC1 : <<include>>
  UC6 .[#7F8C8D].> UC4 : <<include>>
  UC6 .[#7F8C8D].> UC5 : <<include>>
  UC6 .[#7F8C8D].> UC8 : <<include>>
  UC6 .[#7F8C8D].> UC9 : <<include>>
  UC6 .[#E67E22,dashed].> UC7 : <<extend>>
}

trader -[#E74C3C]-> UC1
trader -[#C0392B]-> UC2
trader -[#8E44AD]-> UC3
trader -[#D4AC0D]-> UC4
trader -[#1ABC9C]-> UC6
binance -[#2980B9]-> UC6
binance -[#2980B9]-> UC9
newsapi -[#E67E22]-> UC7

@enduml