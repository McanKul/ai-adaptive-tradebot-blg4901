@startuml Class_Backtest_Data
!theme cerulean-outline
title <size:18>**Backtest - Data Layer**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}

skinparam class<<data>> {
  BackgroundColor #D6EAF8
  BorderColor #2980B9
  HeaderBackgroundColor #AED6F1
}

skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}

skinparam class<<error>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
  HeaderBackgroundColor #F1948A
}

class TickStore <<data>> {
  -config: TickStoreConfig
  -layout: str
  --
  +load(symbol, start_ns, end_ns): Iterator[Tick]
  -_detect_layout(): str
  -_load_legacy(symbol): Iterator[Tick]
  -_load_partitioned(symbol, start, end): Iterator[Tick]
}

class TickStoreConfig <<dataclass>> {
  +data_dir: str
  +file_pattern: str
  +validate: bool
  +deduplicate: bool
}

class DiskTickStreamer <<data>> {
  -tick_store: TickStore
  -symbols: List[str]
  -start_ns: int
  -end_ns: int
  ==
  +stream(): Iterator[Tick]
}

class BarStore <<data>> {
  -bars: Dict[str, Dict[str, List]]
  --
