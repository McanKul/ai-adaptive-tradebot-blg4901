@startuml Class_Strategy_Composite
!theme cerulean-outline
title <size:18>**Strategy - Composite & Regime Detectors**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}
skinparam class<<iface>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
  HeaderBackgroundColor #F1948A
  FontStyle italic
}
skinparam class<<composite>> {
  BackgroundColor #D2B4DE
  BorderColor #8E44AD
  HeaderBackgroundColor #BB8FCE
}
skinparam class<<regime>> {
  BackgroundColor #EBDEF0
  BorderColor #76448A
  HeaderBackgroundColor #D7BDE2
}
skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}

abstract class IStrategy <<iface>>
abstract class IRegimeDetector <<iface>> {
  +detect(bar, ctx): RegimeState
}

class CompositeStrategy <<composite>> {
  -slots: List[StrategySlot]
  -default_sizing: Optional[SizingConfig]
  -regime_detector: Optional[IRegimeDetector]
  -policy: str   ' fixed | regime_gate | regime_weight
  -_slot_exits: Dict[str, ExitManager]
  -_slot_positions: Dict
  --
  +on_bar(bar, ctx): StrategyDecision
}

class StrategySlot <<dataclass>> {
  +id / weight / entry_coefficient
  +strategy: IStrategy
  +sizing / exit / regimes / enabled
}

class ADXRegimeDetector <<regime>> {
  -period / trend_threshold / di_gap
  +detect(bar, ctx): RegimeState
}
class ATRPercentileRegime <<regime>> {
  -atr_period / window / hi_pct / lo_pct
  +detect(bar, ctx): RegimeState
}
class CompositeRegimeDetector <<regime>> {
  -detectors: List[IRegimeDetector]
  +detect(bar, ctx): RegimeState
}

IStrategy <|--[#8E44AD] CompositeStrategy
CompositeStrategy o-[#8E44AD]-> "*" StrategySlot
CompositeStrategy -[#76448A]-> "0..1" IRegimeDetector
StrategySlot -[#8E44AD]-> "1" IStrategy
IRegimeDetector <|--[#76448A] ADXRegimeDetector
IRegimeDetector <|--[#76448A] ATRPercentileRegime
IRegimeDetector <|--[#76448A] CompositeRegimeDetector
CompositeRegimeDetector o-[#76448A]-> "*" IRegimeDetector

note bottom of CompositeStrategy #EBF5FB
  policy:
  • fixed → all enabled slots run
  • regime_gate → slot active only if regimes match
  • regime_weight → all run, entry_coefficient scaled by regime
  Per-slot ExitManager stays active even when gated off.
end note

@enduml

