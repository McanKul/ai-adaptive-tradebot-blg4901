@startuml Class_News
!theme cerulean-outline
title <size:18>**News & Sentiment - Components**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}
skinparam class<<engine>> {
  BackgroundColor #FDEBD0
  BorderColor #E67E22
  HeaderBackgroundColor #F5CBA7
}
skinparam class<<impl>> {
  BackgroundColor #D5F5E3
  BorderColor #27AE60
  HeaderBackgroundColor #ABEBC6
}
skinparam class<<abstract>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
  HeaderBackgroundColor #F1948A
  FontStyle italic
}

abstract class INewsSource <<abstract>> {
  +fetch_news(symbol, limit): List[NewsArticle]
}
abstract class ISentimentAnalyzer <<abstract>> {
  +analyze(texts, symbol): float
}
abstract class IMarginAdjuster <<abstract>> {
  +compute_margin_multiplier(direction, sentiment): float
}

class NewsEngine <<engine>> {
  -news_source: INewsSource
  -sentiment_analyzer: ISentimentAnalyzer
  -refresh_interval / news_limit
  -_cache: Dict[str, Dict]
  --
  +get_sentiment(symbol, force_refresh): float
  +prefetch_symbols(symbols)
}

class CryptoCompareNewsSource <<impl>> {
  -api_key / base_url
  +fetch_news(symbol, limit): List[NewsArticle]
}
class DDGNewsSource <<impl>> {
  -ddgs: DDGS
  +fetch_news(symbol, limit): List[NewsArticle]
}
class OpenAISentimentAnalyzer <<impl>> {
  -model: str
  -_cache: Dict
  +analyze(texts, symbol): float
}
class GeminiSentimentAnalyzer <<impl>> {
  -model_name: gemini-2.5-flash
  -_cache: Dict
  +analyze(texts, symbol): float
}
class SentimentMarginAdjuster <<impl>> {
  -high/low_sentiment_threshold
  -margin_boost_max: 0.5
  +compute_margin_multiplier(direction, sentiment): float
}

INewsSource <|..[#27AE60] CryptoCompareNewsSource
INewsSource <|..[#27AE60] DDGNewsSource
ISentimentAnalyzer <|..[#27AE60] OpenAISentimentAnalyzer
ISentimentAnalyzer <|..[#27AE60] GeminiSentimentAnalyzer
IMarginAdjuster <|..[#27AE60] SentimentMarginAdjuster
NewsEngine -[#E67E22]-> INewsSource
NewsEngine -[#E67E22]-> ISentimentAnalyzer

note bottom of SentimentMarginAdjuster #FEF9E7
  LONG + bullish (>0.75) → margin x(1+boost)
  SHORT + bearish (<0.25) → margin x(1+boost)
  otherwise → x1.0 (no change).
  Sizing boost, <b>not</b> signal gating.
end note

@enduml

