@startuml Class_Backtest_Exit_Risk_Metrics
!theme cerulean-outline
title <size:18>**Backtest - Exit, Risk & Metrics**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}

skinparam class<<risk>> {
  BackgroundColor #FADBD8
  BorderColor #C0392B
  HeaderBackgroundColor #F1948A
}

skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}

skinparam class<<enum>> {
  BackgroundColor #EBF5FB
  BorderColor #2980B9
  HeaderBackgroundColor #AED6F1
}

skinparam class<<metrics>> {
  BackgroundColor #D5F5E3
  BorderColor #27AE60
  HeaderBackgroundColor #ABEBC6
}

class ExitManager <<risk>> {
  -config: ExitConfig
  -positions: Dict[str, PositionState]
  --
  +check_exits(symbol, bar, position): List[Order]
  +on_fill(fill)
  +reset()
}

class ExitConfig <<dataclass>> {
  +take_profit_pct: Optional[float]
  +stop_loss_pct: Optional[float]
  +take_profit_usd: Optional[float]
  +stop_loss_usd: Optional[float]
  +trailing_stop_pct: Optional[float]
  +max_holding_bars: Optional[int]
  +leverage: float
}

enum ExitReason <<enum>> {
  TP_USD
  TP_PCT
  SL_USD
  SL_PCT
  TRAILING
  MAX_BARS
  LIQUIDATION
}

class PositionState <<dataclass>> {
  +entry_price: float
  +quantity: float
  +bars_held: int
  +peak_price: float
}

class BasicRiskManager <<risk>> {
  -limits: RiskLimits
  -daily_pnl: float
  -order_count: int
  -kill_switch: bool
  --
  +pre_trade_check(order, portfolio, bar): bool
  +is_kill_switch_active(): bool
  +update_daily_pnl(pnl)
  +reset_daily()
  +get_state(): Dict
}

class RiskLimits <<dataclass>> {
  +max_position_size: float
  +max_daily_loss: float
  +max_drawdown: float
  +max_leverage: int
  +max_orders_per_day: int
}

class MetricsSink <<metrics>> {
  -equity_curve: List
  -trades: List
  -bars_processed: int
  --
  +on_bar(bar, equity, position)
  +on_order(order)
  +on_fill(fill, portfolio_equity)
  +finalize(...): BacktestResult
  +reset()
}

ExitManager -[#F39C12]-> ExitConfig
ExitManager -[#F39C12]-> "*" PositionState
ExitManager .[#2980B9,dashed].> ExitReason : uses
BasicRiskManager -[#F39C12]-> RiskLimits

@enduml

