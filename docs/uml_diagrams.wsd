@startuml Sequence_Backtest
!theme cerulean-outline
title <size:18>**Sequence Diagram - Backtest Flow**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  sequenceMessageAlign center
  sequenceArrowThickness 2
  maxMessageSize 200
}

skinparam participant {
  FontSize 12
  FontStyle bold
}

skinparam sequence {
  LifeLineBorderColor #2C3E50
  LifeLineBackgroundColor #F8F9F9
  BoxBorderColor #2C3E50
  BoxBackgroundColor #EBF5FB
  DividerBackgroundColor #D5DBDB
  GroupBorderColor #2980B9
  GroupHeaderFontSize 12
}

actor "Trader" as User #F9E79F
participant "BacktestRunner" as Runner #F1948A
participant "BacktestEngine" as Engine #FADBD8
participant "DiskTickStreamer" as Streamer #AED6F1
participant "BarBuilder" as BB #D6EAF8
participant "BarStore" as BS #D6EAF8
participant "IStrategy" as Strat #D2B4DE
participant "RiskManager" as Risk #F1948A
participant "ExecutionModel" as Exec #ABEBC6
participant "Portfolio" as Port #F9E79F
participant "MetricsSink" as Metrics #ABEBC6

User -[#E74C3C]> Runner: run(config)
activate Runner #FADBD8
Runner -[#E74C3C]> Engine: create & configure
activate Engine #FADBD8

loop #EBF5FB for each Tick
  Engine -[#2980B9]> Streamer: next tick
  Streamer --[#2980B9]> Engine: Tick
  Engine -[#2980B9]> BB: process_tick(tick)

  alt #D5F5E3 bar completed
    BB --[#27AE60]> Engine: Bar
    Engine -[#2980B9]> BS: add_bar(symbol, tf, bar)
    Engine -[#8E44AD]> Strat: on_bar(bar, ctx)
    Strat --[#8E44AD]> Engine: StrategyDecision

    loop #FEF9E7 for each Order in decision
      Engine -[#C0392B]> Risk: pre_trade_check(order)
      Risk --[#C0392B]> Engine: approved?

      alt #D5F5E3 approved
        Engine -[#27AE60]> Exec: fill_order(order, bar)
        Exec --[#27AE60]> Engine: Fill
        Engine -[#F39C12]> Port: apply_fill(fill)
        Engine -[#27AE60]> Metrics: on_fill(fill, equity)
      end
    end

    Engine -[#27AE60]> Metrics: on_bar(bar, equity, position)
  end
end

Engine -[#27AE60]> Metrics: finalize()
Metrics --[#27AE60]> Runner: BacktestResult
deactivate Engine
Runner --[#E74C3C]> User: BacktestResult
deactivate Runner

@enduml

' ============================================================
@startuml Sequence_LiveTrading
!theme cerulean-outline
title <size:18>**Sequence Diagram - Live Trading Flow**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  sequenceMessageAlign center
  sequenceArrowThickness 2
  maxMessageSize 200
}

skinparam participant {
  FontSize 12
  FontStyle bold
}

skinparam sequence {
  LifeLineBorderColor #2C3E50
  LifeLineBackgroundColor #F8F9F9
  GroupBorderColor #1ABC9C
  GroupHeaderFontSize 12
}

actor "Trader" as User #F9E79F
participant "live_runner.py" as Runner #FAD7A0
participant "LiveEngine" as Engine #A3E4D7
participant "Streamer" as Stream #AED6F1
participant "BarStore" as BS #D6EAF8
participant "IStrategy" as Strat #D2B4DE
participant "NewsEngine" as News #F5CBA7
participant "SignalCombiner" as Combiner #F5CBA7
participant "PositionManager" as PM #A3E4D7
participant "BinanceBroker" as Broker #AED6F1
participant "GlobalRisk" as GRisk #F1948A

User -[#E67E22]> Runner: start
activate Runner #FDEBD0
Runner -[#1ABC9C]> Engine: create(config)
activate Engine #D1F2EB
Engine -[#2980B9]> Stream: start()
Engine -[#2980B9]> Stream: preload_history()

loop #E8F8F5 async event loop
  Stream -[#2980B9]> BS: add_bar(completed bar)
  Stream -[#1ABC9C]> Engine: bar event via queue

  Engine -[#8E44AD]> Strat: generate_signal(symbol)
  Strat --[#8E44AD]> Engine: signal (BUY/SELL/None)

  alt #FEF9E7 news enabled
    Engine -[#E67E22]> News: get_sentiment(symbol)
    News --[#E67E22]> Engine: sentiment score
    Engine -[#E67E22]> Combiner: combine(signal, sentiment)
    Combiner --[#E67E22]> Engine: final_signal
  end

  alt #D5F5E3 signal exists
    Engine -[#C0392B]> GRisk: check()
    GRisk --[#C0392B]> Engine: allowed?

    alt #D5F5E3 allowed
      Engine -[#1ABC9C]> PM: open_position(symbol, side, qty, price)
      PM -[#2980B9]> Broker: market_order(symbol, side, qty)
      PM -[#2980B9]> Broker: place_stop_market(...)
      PM -[#2980B9]> Broker: place_take_profit(...)
    end
  end
end

deactivate Engine
deactivate Runner

@enduml

