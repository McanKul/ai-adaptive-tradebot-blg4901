actor "Trader" as User #F9E79F
participant "app.py" as CLI #FAD7A0
participant "SweepService" as Svc #F7DC6F
participant "SearchSpace" as SS #F5B7B1
participant "BatchBacktest" as Batch #F1948A
participant "BacktestRunner" as Runner #FADBD8
participant "Scorer" as Scorer #ABEBC6
participant "Selector" as Sel #ABEBC6

User -[#E67E22]> CLI: sweep --param-grid grid.yaml
CLI -[#D4AC0D]> Svc: run_sweep(grid, constraints)
activate Svc #F7DC6F
Svc -[#C0392B]> SS: build grid + constraints
Svc -[#C0392B]> Batch: run(search_space, cv)
activate Batch #F5B7B1
loop #FDEDEC for each param combo
  loop #FEF9E7 for each CV fold (purged / WF / CPCV)
    Batch -[#E74C3C]> Runner: run_once(params)
    Runner --[#E74C3C]> Batch: BacktestResult
  end
  Batch -[#27AE60]> Scorer: score(result)
  Scorer --[#27AE60]> Batch: composite score (+ deflated Sharpe)
end
Batch --[#C0392B]> Svc: BatchResult (ranked)
deactivate Batch
Svc -[#27AE60]> Sel: filter(results, criteria)
Sel --[#27AE60]> Svc: top-N RankedResult
Svc --[#D4AC0D]> User: print_top_results + CSV
deactivate Svc

