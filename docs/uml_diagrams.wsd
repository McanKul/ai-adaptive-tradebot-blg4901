@startuml Class_Interfaces_Regime
!theme cerulean-outline
title <size:18>**Interfaces - Regime Detection & Strategy Slots**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}
skinparam class<<abstract>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
  HeaderBackgroundColor #F1948A
  FontStyle italic
}
skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}

abstract class IRegimeDetector <<abstract>> {
  +{abstract} detect(bar: Bar, ctx): RegimeState
}

class RegimeState <<dataclass>> {
  +tags: List[str]   ' e.g. trend_up, vol_high, range
  +score: Dict[str, float]   ' adx, atr_rank, ...
}

class StrategySlot <<dataclass>> {
  +id: str
  +strategy: IStrategy
  +weight: float
  +entry_coefficient: float
  +sizing: Optional[SizingConfig]
  +exit: Optional[ExitConfig]
  +risk_limits: Optional[Dict]
  +regimes: Optional[List[str]]
  +enabled: bool
}

class AdaptedOutput <<dataclass>> {
  +orders: List[Order]
  +decision: Optional[StrategyDecision]
  +source: str
}

IRegimeDetector -[#27AE60,bold]-> RegimeState : returns
StrategySlot -[#8E44AD]-> IStrategy : wraps

note bottom of StrategySlot #EBF5FB
  adapt_strategy_output(strategy, bar, ctx) → AdaptedOutput
  unifies on_bar() / generate_signal() interfaces;
  apply_sizing_to_orders() then fills real quantities.
end note

@enduml

