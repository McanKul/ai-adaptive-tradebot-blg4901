@startuml Class_Interfaces_Cost_Risk_Metrics
!theme cerulean-outline
title <size:18>**Interfaces - Cost, Risk & Metrics**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}

skinparam class<<protocol>> {
  BackgroundColor #E8DAEF
  BorderColor #8E44AD
  HeaderBackgroundColor #D2B4DE
}

skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}

interface ICostModel <<protocol>> {
  +total_cost(price, qty, side): float
}

interface IFeeModel <<protocol>> {
  +calculate_fee(price, qty, side): float
}

interface ISlippageModel <<protocol>> {
  +calculate_slippage(price, qty, side): float
}

interface ISpreadModel <<protocol>> {
  +calculate_spread_cost(price, qty): float
}

interface ILatencyModel <<protocol>> {
  +get_latency_ns(): int
}

interface IRiskManager <<protocol>> {
  +pre_trade_check(order, portfolio, bar): bool
  +is_kill_switch_active(): bool
  +update_daily_pnl(pnl: float)
  +reset_daily()
  +reset()
  +get_state(): Dict
}

class BacktestResult <<dataclass>> {
  +strategy_name: str
  +params: Dict
  +equity_curve: List
  +trades: List
  .. performance ..
  +total_return: float
  +sharpe_ratio: float
  +max_drawdown: float
  +win_rate: float
  .. costs ..
  +total_fees: float
  +total_slippage: float
}

interface IMetricsSink <<protocol>> {
  +on_bar(bar, equity, position)
  +on_order(order)
  +on_fill(fill, portfolio_equity)
  +finalize(initial_capital, final_equity,\n  start_ts, end_ts): BacktestResult
  +reset()
}

ICostModel .[#8E44AD].> IFeeModel
ICostModel .[#8E44AD].> ISlippageModel
ICostModel .[#8E44AD].> ISpreadModel
ICostModel .[#8E44AD].> ILatencyModel
IMetricsSink -[#27AE60,bold]-> BacktestResult : produces

@enduml

