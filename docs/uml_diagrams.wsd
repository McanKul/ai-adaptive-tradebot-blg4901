@startuml Class_Strategy_Advanced
!theme cerulean-outline
title <size:18>**Strategy - Advanced (Trend, ICT, Arbitrage)**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}
skinparam class<<iface>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
  HeaderBackgroundColor #F1948A
  FontStyle italic
}
skinparam class<<strategy>> {
  BackgroundColor #D5F5E3
  BorderColor #27AE60
  HeaderBackgroundColor #ABEBC6
}
skinparam class<<special>> {
  BackgroundColor #FDEBD0
  BorderColor #E67E22
  HeaderBackgroundColor #F5CBA7
}

abstract class IStrategy <<iface>> {
  +on_bar(bar, ctx): StrategyDecision
}

class EMA_MACD_ATR <<strategy>> {
  -ema_fast (50) / ema_slow (200)
  -macd_fast / macd_slow / macd_signal
  -atr_period / atr_mult / risk_pct
  -allow_reversal / max_holding_bars
  --
  +on_bar(bar, ctx): StrategyDecision
}

class EMACrossMACDTrend <<strategy>> {
  -fast_ema / slow_ema / macd_signal
  -adx_period / adx_threshold
  -rsi filter / volume filter
  -use_ema_slope / exit_on_macd_cross
  --
  +on_bar(bar, ctx): StrategyDecision
}

class ICTLiquiditySweepFVG <<strategy>> {
  -killzone (London / NY AM)
  -HTF bias (swing HH/HL/LL/LH)
  -liquidity sweep + rejection
  -MSS / CHoCH break
  -Fair Value Gap (FVG) >= min_atr
  -OTE 0.62-0.79 confluence
  -rr_target / entry mode
  --
  +on_bar(bar, ctx): StrategyDecision
}

class FundingRateArbStrategy <<special>> {
  -spot vs perpetual basis arb
  -_LegPosition (both legs atomic)
  -exit: timeout | funding flip | converged
  --
  +on_bar(bar, ctx): StrategyDecision
}

class BarSyncBuffer <<special>> {
  -mode: strict | forward_fill
  -tolerance_ns: int
  --
  +update(bar)
  +try_emit(): Optional[MultiBar]
}

IStrategy <|--[#27AE60] EMA_MACD_ATR
IStrategy <|--[#27AE60] EMACrossMACDTrend
IStrategy <|--[#27AE60] ICTLiquiditySweepFVG
IStrategy <|--[#E67E22] FundingRateArbStrategy
FundingRateArbStrategy -[#E67E22]-> BarSyncBuffer : multi-symbol sync

