  HeaderBackgroundColor #F1948A
}
skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}
skinparam class<<util>> {
  BackgroundColor #F2F3F4
  BorderColor #7F8C8D
  HeaderBackgroundColor #D5D8DC
}

class LiveSupervisor <<manager>> {
  -managers: Dict[str, PositionManager]
  --
  +reconcile_on_start()
  +position_qty_for(symbol, strategy): float
}

class PositionManager <<manager>> {
  -broker: IBroker
  -sizing_cfg / exit_cfg / execution_cfg
  -open_positions: Dict[tuple, Position]
  -history: List[Position]
  --
  +position_qty(symbol): float
  +position_qty_for(symbol, strategy): float
}

class Position <<dataclass>> {
  +symbol / side / qty / entry
  +sl / tp: Optional[float]
  +sl_order_id / tp_order_id: int
  +peak_price / peak_pnl
  +slippage_bps / entry_fee_usd / funding_usd
  --
  +unrealized_pnl(price): float
  +update_peak(price)
}

class PositionStore <<util>> {
  -_path: str
  +save(positions) / load() / clear()
}

class LiveGlobalRisk <<risk>> {
  -cfg: GlobalRiskConfig
  -_kill_switch: bool
  -_daily_pnl / _peak_equity
  -_consecutive_losses / _cooldown_until_ts
  --
  +check_account_risk(equity, exposure, n): (bool, str)
  +record_pnl(pnl)
  +trip_kill_switch(reason)
}

class RejectionCounter <<risk>> {
  -max_count / window_seconds
  +record(reason): bool
  +tripped: bool
}

class AsyncRateLimiter <<util>> {
  -_max: int
  +acquire(weight)
}
class ExchangeInfoCache <<util>> {
  -_ttl: int
  +get(fetch_fn): Dict
}

LiveSupervisor o-[#1ABC9C]-> "*" PositionManager
LiveSupervisor .[#7F8C8D,dashed].> PositionStore
PositionManager -[#F39C12]-> "*" Position
PositionManager -[#1ABC9C]-> IBroker

@enduml

