@startuml Component_Architecture
!theme cerulean-outline
title <size:20>**Component Diagram - System Architecture**</size>

skinparam {
  shadowing true
  defaultFontSize 12
  componentStyle rectangle
  ArrowColor #34495E
  ArrowThickness 2
}

skinparam node {
  FontSize 14
  FontStyle bold
}

skinparam component {
  FontSize 11
}

node "Data Sources" <<external>> #EBF5FB {
  [Binance WebSocket] as WS #AED6F1
  [Binance REST API] as REST #AED6F1
  [CryptoCompare API] as CC #F5CBA7
  [Disk Tick Data] as DISK #D5D8DC
}

node "Data Layer" #D6EAF8 {
  [TickStore] as TS #AED6F1
  [DiskTickStreamer] as DS #AED6F1
  [Streamer (Live)] as LS #A3E4D7
  [BarBuilder] as BBL #AED6F1
  [BarStore] as BST #AED6F1
}

node "Intelligence Layer" #E8DAEF {
  [IStrategy] as STRAT #D2B4DE
  [NewsEngine] as NE #F5CBA7
  [SignalCombiner] as SC #F5CBA7
}

node "Execution Layer" #D1F2EB {
  [ExecutionModel (BT)] as EM #ABEBC6
  [BinanceBroker (Live)] as BB #AED6F1
  [PositionManager] as PM #A3E4D7
}

node "Risk Layer" #FADBD8 {
  [RiskManager (BT)] as RM #F1948A
  [GlobalRisk (Live)] as GR #F1948A
  [ExitManager] as EXM #F1948A
}

node "Reporting" #FEF9E7 {
  [MetricsSink] as MS #ABEBC6
  [Scorer] as SCR #ABEBC6
  [Portfolio] as PF #F9E79F
}

DISK -[#7F8C8D]-> TS
TS -[#2980B9]-> DS
WS -[#1ABC9C]-> LS
REST -[#1ABC9C]-> LS
CC -[#E67E22]-> NE

DS -[#2980B9]-> BBL
LS -[#1ABC9C]-> BBL
BBL -[#2980B9]-> BST

BST -[#8E44AD]-> STRAT
NE -[#E67E22]-> SC
STRAT -[#8E44AD]-> SC

SC -[#C0392B]-> RM
SC -[#C0392B]-> GR
RM -[#27AE60]-> EM
GR -[#1ABC9C]-> BB

EM -[#F39C12]-> PF
BB -[#1ABC9C]-> PM

PF -[#27AE60]-> MS
MS -[#27AE60]-> SCR

@enduml

' ============================================================
@startuml State_Position
!theme cerulean-outline
title <size:18>**State Diagram - Position Lifecycle**</size>

skinparam {
  shadowing true
  defaultFontSize 12
  ArrowColor #2C3E50
  ArrowThickness 2
}

skinparam state {
  FontSize 13
  FontStyle bold
  BackgroundColor #D6EAF8
  BorderColor #2980B9
}

skinparam state<<danger>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
}

skinparam state<<success>> {
  BackgroundColor #D5F5E3
  BorderColor #27AE60
}

skinparam state<<active>> {
  BackgroundColor #FDEBD0
  BorderColor #E67E22
}

[*] --> NoPosition

state NoPosition <<success>> {
}

state PendingOpen <<active>> {
}

state Open <<active>> {
}

state TrailingStop <<active>> {
}

state PendingClose <<active>> {
}

state Closed <<success>> {
}

state Liquidated <<danger>> {
}

NoPosition -[#2980B9,bold]-> PendingOpen : Signal received
PendingOpen -[#27AE60,bold]-> Open : Order filled
PendingOpen -[#C0392B]-> NoPosition : Order rejected

Open -[#E67E22]-> TrailingStop : Trailing stop active
Open -[#C0392B]-> PendingClose : TP/SL triggered
Open -[#C0392B]-> PendingClose : Max bars reached
Open -[#7F8C8D]-> PendingClose : Manual close
Open -[#E74C3C,bold]-> Liquidated : Margin call

TrailingStop -[#C0392B]-> PendingClose : Trail triggered
TrailingStop -[#C0392B]-> PendingClose : TP triggered

PendingClose -[#27AE60,bold]-> Closed : Close order filled
Closed -[#2980B9]-> NoPosition : Reset

Liquidated -[#E74C3C]-> NoPosition : Reset

@enduml

' ============================================================
@startuml State_Order
!theme cerulean-outline
title <size:18>**State Diagram - Order Lifecycle**</size>

skinparam {
  shadowing true
  defaultFontSize 12
  ArrowColor #2C3E50
  ArrowThickness 2
}

skinparam state {
  FontSize 13
  FontStyle bold
  BackgroundColor #D6EAF8
  BorderColor #2980B9
}

skinparam state<<warning>> {
  BackgroundColor #FDEBD0
  BorderColor #E67E22
}

skinparam state<<success>> {
  BackgroundColor #D5F5E3
  BorderColor #27AE60
}

skinparam state<<danger>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
}

[*] -[#2980B9,bold]-> PENDING : Order created

state PENDING {
}

state FILLED <<success>> {
}

state PARTIALLY_FILLED <<warning>> {
}

state CANCELLED <<danger>> {
}

state REJECTED <<danger>> {
}

PENDING -[#27AE60,bold]-> FILLED : Fully executed
PENDING -[#E67E22]-> PARTIALLY_FILLED : Partial execution
PENDING -[#C0392B]-> CANCELLED : Cancelled by user/system
PENDING -[#E74C3C]-> REJECTED : Risk check failed

PARTIALLY_FILLED -[#27AE60,bold]-> FILLED : Remaining filled
PARTIALLY_FILLED -[#C0392B]-> CANCELLED : Cancelled remainder

FILLED -[#27AE60]-> [*]
CANCELLED -[#C0392B]-> [*]
REJECTED -[#E74C3C]-> [*]

@enduml

' ============================================================
@startuml UseCase
!theme cerulean-outline
title <size:20>**Use Case Diagram**</size>\n<size:14>AI-Adaptive Trading Bot</size>

skinparam {
  shadowing true
  defaultFontSize 12
  ArrowColor #34495E
  ArrowThickness 1.5
}

skinparam usecase {
  BackgroundColor #D6EAF8
  BorderColor #2980B9
  FontSize 11
  FontStyle bold
}

skinparam actor {
  FontSize 13
  FontStyle bold
}

skinparam rectangle {
  BorderColor #2C3E50
  BackgroundColor #FDFEFE
  FontSize 16
  FontStyle bold
}

left to right direction

actor "Trader" as trader #F9E79F
actor "Binance API" as binance #AED6F1
actor "News API" as newsapi #F5CBA7

rectangle "AI-Adaptive Trading Bot" {
  usecase "Run Backtest" as UC1 #FADBD8
  usecase "Configure Strategy" as UC2 #E8DAEF
  usecase "Start Live Trading" as UC3 #D1F2EB
  usecase "Monitor Positions" as UC4 #D1F2EB
  usecase "Analyze Sentiment" as UC5 #FDEBD0
  usecase "Manage Risk" as UC6 #FADBD8
  usecase "Fetch Tick Data" as UC7 #D6EAF8
  usecase "Score Strategy" as UC8 #D5F5E3
  usecase "View Metrics" as UC9 #D5F5E3

  UC1 .[#7F8C8D].> UC2 : <<include>>
  UC1 .[#7F8C8D].> UC9 : <<include>>
  UC3 .[#7F8C8D].> UC2 : <<include>>
  UC3 .[#E67E22,dashed].> UC5 : <<extend>>
  UC3 .[#7F8C8D].> UC6 : <<include>>
  UC3 .[#7F8C8D].> UC4 : <<include>>
  UC1 .[#27AE60,dashed].> UC8 : <<extend>>
}

trader -[#E74C3C]-> UC1
trader -[#1ABC9C]-> UC3
trader -[#2980B9]-> UC7
trader -[#8E44AD]-> UC2

binance -[#2980B9]-> UC3
binance -[#2980B9]-> UC7
newsapi -[#E67E22]-> UC5

@enduml
