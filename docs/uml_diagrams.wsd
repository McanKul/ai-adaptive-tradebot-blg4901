class NewsArticle <<dataclass>> {
  +title: str
  +content: str
  +source: str
  +published_at: datetime
  +symbol: str
}

abstract class INewsSource <<abstract>> {
  +{abstract} fetch_news(symbol: str, limit: int): List[NewsArticle]
}

abstract class ISentimentAnalyzer <<abstract>> {
  +{abstract} analyze(texts: List[str], symbol: str): float
}

abstract class ISignalCombiner <<abstract>> {
  +{abstract} combine(strategy_signal: Optional[int],\n  sentiment_score: float): Optional[int]
