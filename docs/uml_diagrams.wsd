@startuml Class_Interfaces_MarketData
!theme cerulean-outline
title <size:18>**Interfaces - Market Data & Orders**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classAttributeFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}
skinparam class {
  BackgroundColor #FDFEFE
  BorderColor #2C3E50
  HeaderBackgroundColor #D5DBDB
}
skinparam class<<enum>> {
  BackgroundColor #EBF5FB
  BorderColor #2980B9
  HeaderBackgroundColor #AED6F1
}
skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}

enum OrderType <<enum>> {
  MARKET
  LIMIT
  STOP_MARKET
  TAKE_PROFIT
}

enum OrderSide <<enum>> {
  BUY
  SELL
}

enum OrderStatus <<enum>> {
  PENDING
  FILLED
  PARTIALLY_FILLED
  CANCELLED
  REJECTED
}

class Tick <<dataclass>> {
  +symbol: str
  +timestamp_ns: int
  +price: float
  +volume: float
  +side: str
  +trade_id: int
}

class Bar <<dataclass>> {
  +symbol: str
  +timeframe: str
  +timestamp_ns: int
  .. OHLCV ..
  +open / high / low / close: float
  +volume: float
  .. computed ..
  +tick_count: int
  +dollar_volume: float
  +mid_price / typical_price / vwap: float
}

class Order <<dataclass>> {
  +symbol: str
  +side: OrderSide
  +order_type: OrderType
  +quantity: float
  +price: Optional[float]
  +stop_price: Optional[float]
  +strategy_id: str
  +reduce_only: bool
  +metadata: Dict
}

class Fill <<dataclass>> {
  +order_id: str
  +symbol: str
  +side: OrderSide
  +fill_price: float
  +fill_quantity: float
  +fee: float
  +slippage: float
  +timestamp_ns: int
  +metadata: Dict
}

Order -[#2980B9]-> OrderType
Order -[#2980B9]-> OrderSide
Order -[#2980B9]-> OrderStatus
Fill -[#2980B9]-> OrderSide

@enduml

' ============================================================
@startuml Class_Interfaces_Core
!theme cerulean-outline
title <size:18>**Interfaces - Core Abstractions**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}
skinparam class<<abstract>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
  HeaderBackgroundColor #F1948A
  FontStyle italic
}
skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}

abstract class IStrategy <<abstract>> {
  +{abstract} generate_signal(symbol: str): Optional[str]
  +{abstract} on_bar(bar: Bar, ctx: StrategyContext): StrategyDecision
  +reset()
  +get_exit_params(): Dict
  +get_exit_manager(): Optional
}

class StrategyDecision <<dataclass>> {
  +orders: List[Order]
  +signal: Optional[str]
  +features: Dict
  +metadata: Dict
  +regime_tags: List[str]
}

class StrategyContext <<dataclass>> {
  +symbol / timeframe: str
  +bar_store: BarStore
  +portfolio / position: Any
  +equity / cash: float
  +timestamp_ns: int
  --
  +get_ohlcv(limit): Dict
}

class SizingConfig <<dataclass>> {
  +mode: SizingMode
  +fixed_qty / notional_usd / margin_usd
  +leverage / leverage_mode
  --
  +compute_qty(price): float
  +get_target_notional(): float
}

abstract class IBroker <<abstract>> {
  +{abstract} get_mark_price(symbol): float
  +{abstract} market_order(symbol, side, qty)
  +{abstract} close_position(symbol)
  +{abstract} position_amt(symbol): float
  +{abstract} set_leverage(symbol, leverage)
  +{abstract} place_stop_market(...) : int
  +{abstract} place_take_profit(...) : int
  +{abstract} wait_for_fill(symbol, id, timeout): dict
  +{abstract} get_24h_volume(symbol): float
  +{abstract} balance(asset): float
}

abstract class IClient <<abstract>> {
  +{abstract} futures_exchange_info()
  +{abstract} futures_create_order(**params)
  +{abstract} futures_position_information(symbol)
  +{abstract} futures_account_balance()
  +{abstract} futures_klines(symbol, interval, limit)
  +{abstract} futures_change_leverage(symbol, leverage)
}

abstract class IStreamer <<abstract>> {
  +{abstract} start() / stop()
  +{abstract} get_queue(): asyncio.Queue
  +{abstract} preload_history(symbols, intervals, limit, batch)
}

IStrategy -[#27AE60,bold]-> StrategyDecision : returns
IStrategy -[#2980B9,bold]-> StrategyContext : receives
StrategyContext -[#F39C12]-> SizingConfig
IBroker .[#7F8C8D,dashed].> IClient : uses

@enduml

