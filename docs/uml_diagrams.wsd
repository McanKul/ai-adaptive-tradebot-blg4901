@startuml Class_Strategy_Base
!theme cerulean-outline
title <size:18>**Strategy - Base & Simple Signal Strategies**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}
skinparam class<<abstract>> {
  BackgroundColor #E8DAEF
  BorderColor #8E44AD
  HeaderBackgroundColor #D2B4DE
  FontStyle italic
}
skinparam class<<iface>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
  HeaderBackgroundColor #F1948A
  FontStyle italic
}
skinparam class<<strategy>> {
  BackgroundColor #D5F5E3
  BorderColor #27AE60
  HeaderBackgroundColor #ABEBC6
}

abstract class IStrategy <<iface>> {
  +generate_signal(symbol)
  +on_bar(bar, ctx): StrategyDecision
}

abstract class BinaryBaseStrategy <<abstract>> {
  #bar_store: BarStore
  #buf: DataFrame
  #params: Dict
  --
  +{abstract} _live_signal(o, h, l, c, v): Optional[str]
  +generate_signal(symbol): Optional[str]
  +on_bar(bar, ctx): StrategyDecision
  +reset()
  +get_exit_params(): Dict
}

class RSIThreshold <<strategy>> {
  -rsi_period / rsi_overbought / rsi_oversold
  -position_size: float
  .. exit ..
  -take_profit_pct / stop_loss_pct
  -trailing_stop_pct / max_holding_bars
  -leverage: int
  --
  +_live_signal(o, h, l, c, v): Optional[str]
}

class DonchianATRVolTarget <<strategy>> {
  -dc_period / atr_period / atr_mult
  -risk_pct: float
  -filter_type: str   ' ema | adx | none
  -ema_period / adx_period / adx_threshold
  -allow_reversal / max_holding_bars
  --
  +on_bar(bar, ctx): StrategyDecision
}

IStrategy <|--[#8E44AD] BinaryBaseStrategy
BinaryBaseStrategy <|--[#27AE60] RSIThreshold
IStrategy <|--[#8E44AD] DonchianATRVolTarget

RSIThreshold .[#7F8C8D,dashed].> ExitManager : uses
DonchianATRVolTarget .[#27AE60,dashed].> StrategyDecision : returns
RSIThreshold .[#27AE60,dashed].> StrategyDecision : returns

@enduml

