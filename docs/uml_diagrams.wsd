@startuml Sequence_LiveTrading
!theme cerulean-outline
title <size:18>**Sequence Diagram - Live / Dry-Run Flow**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  sequenceMessageAlign center
  sequenceArrowThickness 2
  maxMessageSize 200
}
skinparam participant {
  FontSize 12
  FontStyle bold
}
skinparam sequence {
  LifeLineBorderColor #2C3E50
  LifeLineBackgroundColor #F8F9F9
  GroupBorderColor #1ABC9C
  GroupHeaderFontSize 12
}

actor "Trader" as User #F9E79F
participant "app.py" as CLI #FAD7A0
participant "LiveService" as Svc #F7DC6F
participant "BrokerFactory" as BF #FCF3CF
participant "LiveEngine" as Engine #A3E4D7
participant "Streamer" as Stream #AED6F1
participant "IStrategy" as Strat #D2B4DE
participant "NewsEngine" as News #F5CBA7
participant "MarginAdjuster" as MA #F5CBA7
participant "GlobalRisk" as GRisk #F1948A
participant "LiveSupervisor" as Sup #A3E4D7
participant "Broker" as Broker #AED6F1

User -[#E67E22]> CLI: live --config / dry-run
CLI -[#E74C3C]> CLI: validate(real_money) + promotion stamp
CLI -[#D4AC0D]> Svc: run(config, dry_run)
activate Svc #F7DC6F
Svc -[#D4AC0D]> BF: create(mode, cfg)
BF --[#D4AC0D]> Svc: IBroker (Binance | Dry)
Svc -[#1ABC9C]> Engine: run()
activate Engine #D1F2EB
Engine -[#2980B9]> Stream: start_buffering / preload_history / flush

loop #E8F8F5 async event loop
  Stream -[#1ABC9C]> Engine: completed bar (via queue)
  Engine -[#8E44AD]> Strat: on_bar(symbol) -> signal

  alt #FEF9E7 news enabled
    Engine -[#E67E22]> News: get_sentiment(symbol)
    News --[#E67E22]> Engine: score [0..1]
    Engine -[#E67E22]> MA: compute_margin_multiplier(dir, score)
    MA --[#E67E22]> Engine: margin x (1.0 .. 1.5)
  end

  alt #D5F5E3 signal exists
    Engine -[#C0392B]> GRisk: check_account_risk()
    GRisk --[#C0392B]> Engine: allowed?
    alt #D5F5E3 allowed
      Engine -[#1ABC9C]> Sup: open_position(symbol, side, margin)
      Sup -[#2980B9]> Broker: market_order(...)
      Sup -[#2980B9]> Broker: place_stop_market / take_profit
    end
  end
end

deactivate Engine
deactivate Svc

@enduml

