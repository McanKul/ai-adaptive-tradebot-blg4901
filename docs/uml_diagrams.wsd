@startuml Class_Live_Config
!theme cerulean-outline
title <size:18>**Live Trading - Configuration**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}
skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}
skinparam class<<config>> {
  BackgroundColor #D1F2EB
  BorderColor #1ABC9C
  HeaderBackgroundColor #A3E4D7
}

class LiveConfig <<config>> {
  +strategy_class / symbols / timeframe
  +symbol_routes: List[SymbolRoute]
  --
  +sizing_for(symbol): SizingConfig
  +exit_for(symbol): ExitConfig
  +leverage_for(symbol): int
  +from_yaml(path) / from_json(path)
  +effective_run_id() / trade_log_path()
}

class SizingConfig <<config>> {
  +mode / leverage / leverage_mode
  +fixed_qty / notional_usd / margin_usd
  +compute_qty(price): float
}
class ExitConfig <<dataclass>> {
  +take_profit_pct/usd / stop_loss_pct/usd
  +trailing_stop_pct / max_holding_bars
  +use_exchange_orders
}
class RiskConfig <<dataclass>> {
  +max_position_size / max_position_notional
  +max_daily_loss / max_leverage
  +max_concurrent_positions
}
class ExecutionConfig <<dataclass>> {
  +margin_type / preload_bars
  +max_entry_spread_bps   ' Phase B1
  +max_slippage_bps       ' Phase B2
  +max_tick_age_seconds   ' Phase E1
}
class NewsConfig <<dataclass>> {
  +enabled / sentiment_provider
  +refresh_interval / news_limit
  +margin_boost_max
}
class GlobalRiskConfig <<dataclass>> {
  +max_daily_loss (USD/%) / max_account_drawdown_pct
  +max_concurrent_positions / cooldown
}
class LiquidationGuardConfig <<dataclass>> {
  +enabled / buffer_pct
  +action   ' close | alarm
}
class SymbolRoute <<config>> {
  +symbol / leverage / margin_usd
  +sizing: SizingConfig
  +exit: ExitConfig
  +enabled: bool
}

LiveConfig -[#1ABC9C]-> "*" SymbolRoute
LiveConfig -[#1ABC9C]-> SizingConfig
LiveConfig -[#F39C12]-> ExitConfig
LiveConfig -[#F39C12]-> RiskConfig
LiveConfig -[#F39C12]-> ExecutionConfig
LiveConfig -[#F39C12]-> NewsConfig
LiveConfig -[#F39C12]-> GlobalRiskConfig
LiveConfig -[#F39C12]-> LiquidationGuardConfig
SymbolRoute -[#1ABC9C]-> SizingConfig
SymbolRoute -[#F39C12]-> ExitConfig

