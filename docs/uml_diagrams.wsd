@startuml Class_Interfaces_Cost_Risk_Metrics
!theme cerulean-outline
title <size:18>**Interfaces - Cost, Risk & Metrics**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}
skinparam class<<protocol>> {
  BackgroundColor #E8DAEF
  BorderColor #8E44AD
  HeaderBackgroundColor #D2B4DE
}
skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}

interface ICostModel <<protocol>> {
  +total_cost(order, fill_price, bar, rng, is_maker): tuple
}
interface IFeeModel <<protocol>> {
  +calculate_fee(notional, side, is_maker): float
}
interface ISlippageModel <<protocol>> {
  +calculate_slippage(price, qty, side, bar, rng): float
}
interface ISpreadModel <<protocol>> {
  +calculate_spread_cost(price, side): float
}
interface ILatencyModel <<protocol>> {
  +get_latency_ns(rng): int
}
interface IRiskManager <<protocol>> {
  +pre_trade_check(order, portfolio, bar): bool
  +is_kill_switch_active(): bool
  +update_daily_pnl(pnl)
  +reset_daily() / reset()
  +get_state(): Dict
}

class BacktestResult <<dataclass>> {
  +strategy_name: str
  +params: Dict
  +equity_curve / trades: List
  .. performance ..
  +total_return / sharpe_ratio: float
  +max_drawdown / win_rate: float
  +profit_factor / calmar_ratio: float
  .. costs ..
  +total_fees / total_slippage: float
}

interface IMetricsSink <<protocol>> {
  +on_bar(bar, equity, position)
  +on_order(order)
  +on_fill(fill, portfolio_equity)
  +finalize(...): BacktestResult
}

ICostModel .[#8E44AD,dashed].> IFeeModel
ICostModel .[#8E44AD,dashed].> ISlippageModel
ICostModel .[#8E44AD,dashed].> ISpreadModel
ICostModel .[#8E44AD,dashed].> ILatencyModel
IMetricsSink -[#27AE60,bold]-> BacktestResult : produces

@enduml

