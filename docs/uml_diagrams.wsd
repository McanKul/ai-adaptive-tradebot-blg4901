@startuml Class_Backtest_Scoring
!theme cerulean-outline
title <size:18>**Backtest - Scoring & Cross-Validation**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}
