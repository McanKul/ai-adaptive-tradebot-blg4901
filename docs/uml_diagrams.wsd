@startuml Class_Backtest_Engine
!theme cerulean-outline
title <size:18>**Backtest - Engine & Core Components**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}

skinparam class {
  BackgroundColor #FDFEFE
  BorderColor #2C3E50
  HeaderBackgroundColor #D5DBDB
}

skinparam class<<engine>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
  HeaderBackgroundColor #F1948A
}

skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}

skinparam class<<enum>> {
  BackgroundColor #EBF5FB
  BorderColor #2980B9
  HeaderBackgroundColor #AED6F1
}

class BacktestEngine <<engine>> {
  -tick_store: TickStore
  -disk_streamer: DiskTickStreamer
  -bar_builders: Dict[str, BarBuilder]
  -bar_store: BarStore
  -strategy: IStrategy
  -risk_manager: BasicRiskManager
  -execution_model: SimpleExecutionModel
  -portfolio: Portfolio
  -metrics_sink: MetricsSink
  -exit_manager: ExitManager
  -cost_model: CompositeCostModel
  ==
  +run(): BacktestResult
}

class Portfolio {
  -cash: float
  -positions: Dict[str, Position]
  -leverage_mode: LeverageMode
  -margin_config: MarginConfig
  --
  +apply_fill(fill: Fill, price: float)
  +equity(prices: Dict): float
  +realized_pnl(): float
  +unrealized_pnl(prices): float
}

class Position <<dataclass>> {
  +symbol: str
  +quantity: float
  +avg_entry_price: float
  +realized_pnl: float
  +fees: float
  +slippage: float
}

enum LeverageMode <<enum>> {
  SPOT
  MARGIN
}

class MarginConfig <<dataclass>> {
  +leverage: int
  +maintenance_margin_ratio: float
  +liquidation_buffer: float
}

BacktestEngine -[#E74C3C]-> Portfolio
BacktestEngine -[#E74C3C]-> "1" IStrategy
BacktestEngine -[#E74C3C]-> "1" MetricsSink
BacktestEngine -[#E74C3C]-> "*" BarBuilder
BacktestEngine -[#E74C3C]-> "1" SimpleExecutionModel
BacktestEngine -[#E74C3C]-> "1" BasicRiskManager
BacktestEngine -[#E74C3C]-> "1" ExitManager
BacktestEngine -[#E74C3C]-> "1" BarStore
BacktestEngine -[#E74C3C]-> "1" DiskTickStreamer
Portfolio -[#F39C12]-> "*" Position
Portfolio -[#2980B9]-> LeverageMode
Portfolio -[#F39C12]-> MarginConfig

@enduml

