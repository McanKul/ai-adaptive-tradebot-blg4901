class SupportResistanceTracker <<data>> {
  -window / num_levels
  +update(bar)
  +get_levels(): SupportResistanceResult
}
class SupportResistanceResult <<dataclass>> {
  +levels / supports / resistances: List[float]
  +method: str
}

class LeverageConfig <<dataclass>> {
  +leverage / taker_fee_bps / maker_fee_bps
  +maintenance_margin_ratio
  +initial_margin_rate / maintenance_margin_rate
}

class "levels" as LVL <<util>> {
  +compute_pivot_levels(...): SupportResistanceResult
  +detect_swing_levels(...): SupportResistanceResult
  +cluster_levels(levels, tol): List
  +find_nearest_level(price, levels, dir): float
}

class "leverage_utils" as LU <<util>> {
  +calculate_notional(qty, price): float
  +calculate_margin_required(qty, price, lev): float
  +calculate_unrealized_pnl(qty, entry, current): float
  +calculate_liquidation_price(...): float
  +is_liquidation_triggered(...): bool
  +calculate_position_size_from_margin(margin, price, lev): float
  +validate_order_against_limits(...): tuple
}

class "logger" as LOG <<util>> {
  +log(level, message)
  +setup_logger(name, level): Logger
}

LVL .[#2980B9,dashed].> SupportResistanceResult : produces
SupportResistanceTracker -[#2980B9]-> SupportResistanceResult

