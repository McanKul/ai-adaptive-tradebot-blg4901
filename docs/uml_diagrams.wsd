  BackgroundColor #F2F3F4
  BorderColor #7F8C8D
  HeaderBackgroundColor #D5D8DC
  FontStyle italic
}

class NewsArticle <<dataclass>> {
  +title: str
  +content: str
  +source: str
  +published_at: str
  +symbol: str
}

abstract class INewsSource <<abstract>> {
  +{abstract} fetch_news(symbol: str, limit: int): List[NewsArticle]
}

abstract class ISentimentAnalyzer <<abstract>> {
  +{abstract} analyze(texts: List[str], symbol: str): float
}

abstract class IMarginAdjuster <<abstract>> {
  +{abstract} compute_margin_multiplier(direction: int,\n  sentiment_score: float): float
}

abstract class ISignalCombiner <<deprecated>> {
  +{abstract} combine(strategy_signal,\n  sentiment_score): Optional[int]
}

INewsSource -[#27AE60,bold]-> NewsArticle : produces

note bottom of IMarginAdjuster #FEF9E7
  <b>Replaces ISignalCombiner.</b>
  Sentiment no longer gates the signal — it
  scales position margin (boost up to +50%).
end note

@enduml

