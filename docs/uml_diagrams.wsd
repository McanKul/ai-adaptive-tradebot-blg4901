@startuml Sequence_NewsSentiment
!theme cerulean-outline
title <size:18>**Sequence Diagram - News Sentiment -> Margin**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  sequenceMessageAlign center
  sequenceArrowThickness 2
  maxMessageSize 200
}
skinparam participant {
  FontSize 12
  FontStyle bold
}
skinparam sequence {
  LifeLineBorderColor #2C3E50
  LifeLineBackgroundColor #F8F9F9
  GroupBorderColor #E67E22
  GroupHeaderFontSize 12
}

participant "LiveEngine" as Engine #A3E4D7
participant "NewsEngine" as NE #F5CBA7
participant "INewsSource" as Source #ABEBC6
participant "ISentimentAnalyzer" as SA #D2B4DE
participant "MarginAdjuster" as MA #F5CBA7

Engine -[#E67E22]> NE: get_sentiment("BTCUSDT")
activate NE #FDEBD0

alt #FEF9E7 cache miss or expired
  NE -[#27AE60]> Source: fetch_news("BTCUSDT", limit=5)
  activate Source #D5F5E3
  Source --[#27AE60]> NE: List[NewsArticle]
  deactivate Source

  NE -[#E67E22]> NE: extract titles + content
  NE -[#8E44AD]> SA: analyze(texts, "BTCUSDT")
  activate SA #E8DAEF
  SA --[#8E44AD]> NE: sentiment_score (0.0 - 1.0)
  deactivate SA
  NE -[#E67E22]> NE: cache result (TTL)
end

NE --[#E67E22]> Engine: sentiment_score
deactivate NE

Engine -[#E67E22]> MA: compute_margin_multiplier(direction=LONG, sentiment=0.80)
activate MA #FDEBD0

alt #D5F5E3 LONG + sentiment > 0.75
  MA --[#27AE60]> Engine: **margin x 1.5 (boost)**
else #FADBD8 SHORT + sentiment < 0.25
  MA --[#C0392B]> Engine: **margin x 1.5 (boost)**
else #F2F3F4 direction disagrees
  MA --[#7F8C8D]> Engine: **margin x 1.0 (unchanged)**
end

deactivate MA

@enduml

' ============================================================
@startuml Activity_SignalFlow
!theme cerulean-outline
title <size:18>**Activity Diagram - Live Signal & Margin Flow**</size>

skinparam {
  shadowing true
  defaultFontSize 12
  ActivityFontSize 12
  ArrowColor #2C3E50
  ArrowThickness 2
}
skinparam activity {
  BackgroundColor #D6EAF8
  BorderColor #2980B9
  FontStyle bold
}
skinparam diamond {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
}

|#EBF5FB| Data Layer
start
:Bar Completed (via Streamer);

|#E8DAEF| Intelligence Layer
:Strategy.on_bar(bar, ctx);

if (Signal generated?) then (<color:#27AE60>yes</color>)
  :direction = LONG / SHORT;

  if (News enabled?) then (<color:#27AE60>yes</color>)
    |#FDEBD0| News Layer
    :NewsEngine.get_sentiment(symbol);
    :sentiment_score = [0.0 - 1.0];
    :MarginAdjuster.compute_margin_multiplier();

    if (direction agrees w/ sentiment?) then (<color:#27AE60>yes</color>)
      #ABEBC6:margin x= (1 + boost)  up to +50%;
    else (<color:#7F8C8D>no</color>)
      #D5D8DC:margin x= 1.0  (unchanged);
    endif
  else (<color:#7F8C8D>no</color>)
    :margin = base sizing;
  endif

  |#FADBD8| Risk Layer
  :GlobalRisk.check_account_risk();

  if (Allowed?) then (<color:#27AE60>yes</color>)
    |#D1F2EB| Execution Layer
    :Compute qty from margin x leverage;
    :Broker.market_order();
    :place_stop_market / take_profit;
    :LiveSupervisor tracks position;
  else (<color:#C0392B>no</color>)
    #F1948A:Log rejection / maybe kill-switch;
  endif

else (<color:#7F8C8D>no</color>)
  #D5D8DC:No action;
endif

stop

@enduml

