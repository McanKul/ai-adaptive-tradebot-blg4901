@startuml Class_Backtest_BarBuilder
!theme cerulean-outline
title <size:18>**Backtest - Bar Builder Hierarchy**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}

skinparam class<<abstract>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
  HeaderBackgroundColor #F1948A
  FontStyle italic
}

skinparam class<<concrete>> {
  BackgroundColor #D5F5E3
  BorderColor #27AE60
  HeaderBackgroundColor #ABEBC6
}

abstract class BarBuilder <<abstract>> {
  #symbol: str
  #current_bar: Optional[Bar]
  #bar_count: int
  --
  +{abstract} _should_close_bar(tick: Tick): bool
  +process_tick(tick: Tick): Optional[Bar]
  +flush(): Optional[Bar]
}

class TimeBarBuilder <<concrete>> {
  -timeframe: str
  -interval_ns: int
  --
  +_should_close_bar(tick: Tick): bool
}

class TickBarBuilder <<concrete>> {
  -tick_count_threshold: int
  -current_tick_count: int
  --
  +_should_close_bar(tick: Tick): bool
}

class VolumeBarBuilder <<concrete>> {
  -volume_threshold: float
  -current_volume: float
  --
  +_should_close_bar(tick: Tick): bool
}

class DollarBarBuilder <<concrete>> {
  -dollar_threshold: float
  -current_dollar_volume: float
  --
  +_should_close_bar(tick: Tick): bool
}

BarBuilder <|-- TimeBarBuilder
BarBuilder <|-- TickBarBuilder
BarBuilder <|-- VolumeBarBuilder
BarBuilder <|-- DollarBarBuilder

note bottom of BarBuilder #FDEBD0
  <b>Factory Pattern</b>
  create_bar_builder(type, symbol, params)
  ----
  Tick → Bar dönüşümü için
  farklı bar türlerini destekler
end note

BarBuilder .[#7F8C8D,dashed].> Tick : processes
BarBuilder .[#27AE60,dashed].> Bar : produces

@enduml

' ============================================================
@startuml Class_Backtest_Execution
!theme cerulean-outline
title <size:18>**Backtest - Execution & Cost Models**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}

skinparam class<<main>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
  HeaderBackgroundColor #F1948A
}

skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}

skinparam class<<cost>> {
  BackgroundColor #D5F5E3
  BorderColor #27AE60
  HeaderBackgroundColor #ABEBC6
}

class SimpleExecutionModel <<main>> {
  -cost_model: CompositeCostModel
  -partial_fill_config: PartialFillConfig
  -latency_config: LatencyConfig
  -stats: ExecutionStats
  -rng: Random
  ==
  +fill_order(order: Order, bar: Bar): Optional[Fill]
}

class ExecutionStats <<dataclass>> {
  +total_fills: int
  +total_rejections: int
  +total_partial: int
  +latency_samples: List[int]
}

class PartialFillConfig <<dataclass>> {
  +enabled: bool
  +min_fill_ratio: float
  +volume_participation_rate: float
}

class LatencyConfig <<dataclass>> {
  +enabled: bool
  +mean_ns: int
  +std_ns: int
}

class ReservoirSampler {
  -capacity: int
  -samples: List
  -count: int
  --
  +add(item)
  +get_samples(): List
}

class CompositeCostModel <<main>> {
  -fee_model: IFeeModel
  -slippage_model: ISlippageModel
  -spread_model: ISpreadModel
  -latency_model: ILatencyModel
  ==
  +total_cost(price, qty, side): float
}

class FixedFeeModel <<cost>> {
  -maker_rate: float
  -taker_rate: float
  +calculate_fee(price, qty, side): float
}

class FixedSlippageModel <<cost>> {
  -slippage_bps: float
  +calculate_slippage(price, qty, side): float
}

class SpreadCostModel <<cost>> {
  -spread_bps: float
  +calculate_spread_cost(price, qty): float
}

class LatencyModel <<cost>> {
  -base_ns: int
  -jitter_ns: int
  +get_latency_ns(): int
}

SimpleExecutionModel -[#E74C3C]-> CompositeCostModel
SimpleExecutionModel -[#F39C12]-> PartialFillConfig
SimpleExecutionModel -[#F39C12]-> LatencyConfig
SimpleExecutionModel -[#F39C12]-> ExecutionStats
SimpleExecutionModel -[#7F8C8D]-> ReservoirSampler
CompositeCostModel -[#27AE60]-> FixedFeeModel
CompositeCostModel -[#27AE60]-> FixedSlippageModel
CompositeCostModel -[#27AE60]-> SpreadCostModel
CompositeCostModel -[#27AE60]-> LatencyModel

@enduml

