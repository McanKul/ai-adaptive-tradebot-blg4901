@startuml Package_Overview
!theme cerulean-outline
title <size:20>**AI-Adaptive Trading Bot**</size>\n<size:14>Proje Paket Diyagramı</size>

skinparam {
  packageStyle frame
  packageBorderColor #2C3E50
  packageFontSize 14
  packageFontStyle bold
  componentStyle rectangle
  shadowing true
  defaultFontSize 12
  ArrowColor #34495E
  ArrowThickness 2
}

skinparam package<<interface>> {
  BackgroundColor #EBF5FB
  BorderColor #2980B9
}

skinparam package<<backtest>> {
  BackgroundColor #FDEDEC
  BorderColor #E74C3C
}

skinparam package<<strategy>> {
  BackgroundColor #F9EBEA
  BorderColor #8E44AD
}

skinparam package<<live>> {
  BackgroundColor #E8F8F5
  BorderColor #1ABC9C
}

skinparam package<<news>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
}

skinparam package<<utils>> {
  BackgroundColor #F2F3F4
  BorderColor #7F8C8D
}

skinparam package<<entry>> {
  BackgroundColor #FDEBD0
  BorderColor #E67E22
}

package "Interfaces" <<interface>> as IF {
  [IStrategy] #D6EAF8
  [IBroker] #D6EAF8
  [IClient] #D6EAF8
  [ISignalCombiner] #D6EAF8
  [ISentimentAnalyzer] #D6EAF8
  [INewsSource] #D6EAF8
  [IStreamer] #D6EAF8
  [market_data] #AED6F1
  [orders] #AED6F1
  [cost_interface] #AED6F1
  [metrics_interface] #AED6F1
  [risk_interface] #AED6F1
  [strategy_adapter] #AED6F1
}

package "Backtest" <<backtest>> as BT {
  [engine] #FADBD8
  [portfolio] #FADBD8
  [bar_builder] #FADBD8
  [execution_models] #FADBD8
  [cost_models] #FADBD8
  [metrics] #FADBD8
  [exit_manager] #FADBD8
  [risk] #FADBD8
  [tick_store] #FADBD8
  [disk_streamer] #FADBD8
  [realism_config] #FADBD8
  [runner] #FADBD8
  package "scoring" {
    [scorer] #F5B7B1
    [batch] #F5B7B1
    [search_space] #F5B7B1
    [selector] #F5B7B1
    [splits] #F5B7B1
  }
}

package "Strategy" <<strategy>> as ST {
  [binary_base_strategy] #E8DAEF
  [RSIThreshold] #E8DAEF
  [DonchianATRVolTarget] #E8DAEF
}

package "Live Trading" <<live>> as LV {
  [live_engine] #D1F2EB
  [broker_binance] #D1F2EB
  [binance_client] #D1F2EB
  [live_config] #D1F2EB
  [position_manager] #D1F2EB
  [global_risk] #D1F2EB
  [rate_limiter] #D1F2EB
  [streamer] #D1F2EB
}

package "News & Sentiment" <<news>> as NW {
  [signal_combiner] #FDEBD0
  [crypto_news_source] #FDEBD0
  [openai_sentiment] #FDEBD0
  [gemini_sentiment] #FDEBD0
  [news_engine] #FDEBD0
}

package "Utils" <<utils>> as UT {
  [bar_store] #D5D8DC
  [logger] #D5D8DC
  [leverage_utils] #D5D8DC
  [levels] #D5D8DC
}

package "Entry Points" <<entry>> as EP {
  [main.py] #FAD7A0
  [live_runner.py] #FAD7A0
  [run_unified_backtest.py] #FAD7A0
}

BT -[#2980B9]-> IF : <<implements>>
ST -[#8E44AD]-> IF : <<implements>>
LV -[#1ABC9C]-> IF : <<implements>>
NW -[#F39C12]-> IF : <<implements>>
BT -[#7F8C8D,dashed]-> UT : <<uses>>
LV -[#7F8C8D,dashed]-> UT : <<uses>>
LV -[#F39C12,dashed]-> NW : <<uses>>
EP -[#E74C3C,bold]-> BT : <<runs>>
EP -[#1ABC9C,bold]-> LV : <<runs>>
EP -[#8E44AD,dashed]-> ST : <<configures>>

@enduml

' ============================================================
@startuml Class_Interfaces_MarketData
!theme cerulean-outline
title <size:18>**Interfaces - Market Data & Orders**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classAttributeFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}

skinparam class {
  BackgroundColor #FDFEFE
  BorderColor #2C3E50
  HeaderBackgroundColor #D5DBDB
}

skinparam class<<enum>> {
  BackgroundColor #EBF5FB
  BorderColor #2980B9
  HeaderBackgroundColor #AED6F1
}

skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}

enum OrderType <<enum>> {
  MARKET
  LIMIT
  STOP_MARKET
  TAKE_PROFIT
}

enum OrderSide <<enum>> {
  BUY
  SELL
  --
  +from_string(s: str): OrderSide
}

enum OrderStatus <<enum>> {
  PENDING
  FILLED
  PARTIALLY_FILLED
  CANCELLED
  REJECTED
}

class Tick <<dataclass>> {
  +symbol: str
  +timestamp_ns: int
  +price: float
  +volume: float
  +side: str
  +trade_id: int
  .. derived ..
  +timestamp_ms: float
  +timestamp_s: float
}

class Bar <<dataclass>> {
  +symbol: str
  +timeframe: str
  +timestamp_ns: int
  .. OHLCV ..
  +open: float
  +high: float
  +low: float
  +close: float
  +volume: float
  .. computed ..
  +tick_count: int
  +dollar_volume: float
  +mid_price: float
  +typical_price: float
  +vwap: float
}

class Order <<dataclass>> {
  +symbol: str
  +side: OrderSide
  +type: OrderType
  +quantity: float
  +price: Optional[float]
  +stop_price: Optional[float]
  +reduce_only: bool
  +metadata: Dict
}

class Fill <<dataclass>> {
  +order_id: str
  +symbol: str
  +side: OrderSide
  +fill_price: float
  +fill_quantity: float
  +fee: float
  +slippage: float
  +timestamp_ns: int
}

Order -[#2980B9]-> OrderType
Order -[#2980B9]-> OrderSide
Order -[#2980B9]-> OrderStatus
Fill -[#2980B9]-> OrderSide

@enduml

' ============================================================
@startuml Class_Interfaces_Core
!theme cerulean-outline
title <size:18>**Interfaces - Core Abstractions**</size>

skinparam {
  shadowing true
  defaultFontSize 11
  classFontSize 13
  classFontStyle bold
  ArrowColor #34495E
  ArrowThickness 1.5
}

skinparam class<<abstract>> {
  BackgroundColor #FADBD8
  BorderColor #E74C3C
  HeaderBackgroundColor #F1948A
  FontStyle italic
}

skinparam class<<dataclass>> {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  HeaderBackgroundColor #F9E79F
}

abstract class IStrategy <<abstract>> {
  +{abstract} generate_signal(symbol: str): Optional[str]
  +{abstract} on_bar(bar: Bar, ctx: StrategyContext): StrategyDecision
  +reset()
}

class StrategyDecision <<dataclass>> {
  +orders: List[Order]
  +signal: Optional[str]
  +features: Dict
  +metadata: Dict
  +regime_tags: List[str]
}

class StrategyContext <<dataclass>> {
  +symbol: str
  +timeframe: str
  +bar_store: BarStore
  +portfolio: Any
  +position: Any
  +equity: float
  +cash: float
  --
  +get_ohlcv(): DataFrame
  +get_position(): Any
}

abstract class IBroker <<abstract>> {
  +{abstract} get_mark_price(symbol: str): float
  +{abstract} market_order(symbol, side, qty)
  +{abstract} close_position(symbol)
  +{abstract} position_amt(symbol): float
  +{abstract} set_leverage(symbol, leverage)
  +{abstract} place_stop_market(symbol, side, qty, stop_price)
  +{abstract} place_take_profit(symbol, side, qty, price)
  +{abstract} get_open_orders(symbol): list
  +{abstract} balance(asset): float
}

abstract class IClient <<abstract>> {
  +{abstract} futures_exchange_info()
  +{abstract} futures_mark_price(symbol)
  +{abstract} futures_create_order(**params)
  +{abstract} futures_position_information(symbol)
  +{abstract} futures_account_balance()
  +{abstract} futures_klines(symbol, interval, limit)
  +{abstract} futures_change_margin_type(symbol, marginType)
  +{abstract} futures_change_leverage(symbol, leverage)
}

abstract class IStreamer <<abstract>> {
  +{abstract} start()
  +{abstract} stop()
  +{abstract} get_queue(): asyncio.Queue
  +{abstract} preload_history(symbols, intervals, limit, batch)
}

IStrategy -[#27AE60,bold]-> StrategyDecision : returns
IStrategy -[#2980B9,bold]-> StrategyContext : receives
IBroker .[#7F8C8D,dashed].> IClient : uses

@enduml

' ============================================================
@startuml Class_Interfaces_News
!theme cerulean-outline
title <size:18>**Interfaces - News & Sentiment**</size>

skinparam {
